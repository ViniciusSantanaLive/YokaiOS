<Page x:Class="YokaiOS_Toolbox.Pages.RestorePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Restaurar" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Restaure as configuracoes padrao do Windows" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <TextBlock Text="Use se algo parar de funcionar apos as otimizacoes." FontSize="14" Foreground="{StaticResource YokaiText2}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                <Button Content="Restaurar Tudo" Style="{StaticResource DangerBtn}" Click="Restore_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
