<Page x:Class="YokaiOS_Toolbox.Pages.RestorePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Restaurar" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="Restaure as configuracoes padrao do Windows" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Use se algo parar de funcionar apos as otimizacoes. O script de backup foi criado automaticamente antes da instalacao." FontSize="14" Foreground="{ThemeResource YokaiTextSecondaryBrush}" TextWrapping="Wrap"/>
                    <Button Content="Restaurar Tudo" Style="{StaticResource YokaiButtonDangerStyle}" Click="Restore_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
