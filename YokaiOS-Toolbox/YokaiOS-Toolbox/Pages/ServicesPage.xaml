<Page x:Class="YokaiOS_Toolbox.Pages.ServicesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Servicos" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="50+ servicos desabilitados para reduzir processos em idle" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <ListBox x:Name="SvcList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource YokaiText}" FontFamily="Cascadia Code" FontSize="13" MaxHeight="400"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
