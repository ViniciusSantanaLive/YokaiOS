<Page x:Class="YokaiOS_Toolbox.Pages.ServicesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Servicos" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="50+ servicos desabilitados para reduzir processos em idle" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <ListView x:Name="ServicesList" SelectionMode="None" MaxHeight="500">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontFamily="Cascadia Code" FontSize="13" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="13" Foreground="{ThemeResource YokaiRedBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
