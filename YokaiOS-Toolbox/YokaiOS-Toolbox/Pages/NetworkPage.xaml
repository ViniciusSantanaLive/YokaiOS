<Page x:Class="YokaiOS_Toolbox.Pages.NetworkPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Rede" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="Otimizacoes de rede para baixa latencia" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <ToggleSwitch Header="Desabilitar Algoritmo de Nagle" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Otimizar TCP Settings" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="DNS Cloudflare (1.1.1.1)" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Network Throttling" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Teredo" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="IPv4 Preferencial" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Network Power Saving" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Flush DNS Cache" OnContent="" OffContent="" IsOn="True"/>
                    </StackPanel>
                    <Button Content="Aplicar Rede" Style="{StaticResource YokaiButtonStyle}" Click="Apply_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
