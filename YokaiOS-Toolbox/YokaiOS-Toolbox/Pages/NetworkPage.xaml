<Page x:Class="YokaiOS_Toolbox.Pages.NetworkPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Rede" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Otimizacoes de rede para baixa latencia" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <CheckBox Content="Desabilitar Algoritmo de Nagle" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Otimizar TCP Settings" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="DNS Cloudflare (1.1.1.1)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Network Throttling" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Teredo" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="IPv4 Preferencial" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,16"/>
                <Button Content="Aplicar Rede" Style="{StaticResource PrimaryBtn}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
