<Page x:Class="YokaiOS_Toolbox.Pages.NetworkPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Rede" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                    <TextBlock Text="Otimizacoes de rede para baixa latencia" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="OTIMIZACOES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="0,0,0,16"/>
                    
                    <CheckBox x:Name="ChkNagle" Content="Desabilitar Algoritmo de Nagle" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkTCP" Content="Otimizar TCP Settings" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkDNS" Content="DNS Cloudflare (1.1.1.1)" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkThrottling" Content="Desabilitar Network Throttling" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkTeredo" Content="Desabilitar Teredo" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkIPv4" Content="IPv4 Preferencial" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <Button Style="{StaticResource PrimaryBtn}" Click="Apply_Click">
                    <TextBlock Text="Aplicar Rede"/>
                </Button>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>