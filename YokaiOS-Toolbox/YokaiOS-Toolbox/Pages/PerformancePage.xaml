<Page x:Class="YokaiOS_Toolbox.Pages.PerformancePage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Performance" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                    <TextBlock Text="50+ servicos, 60+ tarefas, otimizacoes" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="FEATURES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="0,0,0,16"/>
                    
                    <CheckBox x:Name="ChkServices" Content="Desabilitar 50+ Servicos Desnecessarios" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkTasks" Content="Desabilitar 60+ Tarefas Agendadas" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkPowerPlan" Content="Plano Ultimate Performance" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkMitigations" Content="Desabilitar Mitigacoes de CPU" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkDarkMode" Content="Modo Escuro" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkContextMenu" Content="Menu Contexto Classico" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkReservedStorage" Content="Desabilitar Reserved Storage" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <Button Style="{StaticResource PrimaryBtn}" Click="Apply_Click">
                    <TextBlock Text="Aplicar Performance"/>
                </Button>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>