<Page x:Class="YokaiOS_Toolbox.Pages.PerformancePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Performance" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="50+ servicos, 60+ tarefas, otimizacoes WinUtil" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <CheckBox Content="Desabilitar 50+ Servicos Desnecessarios" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar 60+ Tarefas Agendadas" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Otimizar Memoria (Sem Compressao)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Plano Ultimate Performance" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Mitigacoes de CPU" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Reserved Storage" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="End Task no Taskbar" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Menu Contexto Classico" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Modo Escuro" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,16"/>
                <Button Content="Aplicar Performance" Style="{StaticResource PrimaryBtn}" Click="Apply_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
