<Page x:Class="YokaiOS_Toolbox.Pages.BenchmarkPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Benchmark" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="Compare performance antes e depois das otimizacoes" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <Border Background="{ThemeResource YokaiBg2Brush}" CornerRadius="8" Padding="16" MinHeight="300">
                        <ScrollViewer>
                            <TextBlock x:Name="BenchmarkOutput" Text="Clique em 'Executar Benchmark' para comecar..." FontFamily="Cascadia Code" FontSize="13" Foreground="{ThemeResource YokaiGreenBrush}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                    <Button Content="Executar Benchmark" Style="{StaticResource YokaiButtonStyle}" Click="RunBenchmark_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
