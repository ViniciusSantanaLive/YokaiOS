<Page x:Class="YokaiOS_Toolbox.Pages.BenchmarkPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Benchmark" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Compare performance antes e depois" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <Border Background="{StaticResource YokaiBg2}" CornerRadius="8" Padding="16" MinHeight="200">
                    <ScrollViewer>
                        <TextBlock x:Name="Output" Text="Clique em Executar para comecar..." FontFamily="Cascadia Code" FontSize="13" Foreground="{StaticResource YokaiGreen}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
                <Button Content="Executar Benchmark" Style="{StaticResource PrimaryBtn}" Margin="0,16,0,0" Click="Run_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
