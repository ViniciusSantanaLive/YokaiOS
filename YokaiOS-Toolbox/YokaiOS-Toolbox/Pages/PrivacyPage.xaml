<Page x:Class="YokaiOS_Toolbox.Pages.PrivacyPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Privacidade" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="20+ otimizacoes para eliminar telemetria e tracking" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <ToggleSwitch Header="Desabilitar Telemetria" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Tracking e Advertising ID" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Activity Feed" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Cortana" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Busca Web (Bing)" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Propagandas" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Location Tracking" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Input Personalization" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar SmartScreen" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Cloud Search" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Feedback" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar WiFi Sense" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar App Diagnostics" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Speech Recognition" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Search History" OnContent="" OffContent="" IsOn="True"/>
                    </StackPanel>
                    <Button Content="Aplicar Privacidade" Style="{StaticResource YokaiButtonStyle}" Click="Apply_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
