<Page x:Class="YokaiOS_Toolbox.Pages.GamingPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <Page.Resources>
        <Style x:Key="FeatureCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource YokaiGradientCard}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource YokaiBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource YokaiBorderLight}"/>
                    <Setter Property="Background" Value="{StaticResource YokaiCardHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header Card -->
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="48" Height="48" CornerRadius="12" Background="#8B5CF615" Margin="0,0,16,0">
                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{StaticResource YokaiPurple}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizacoes Gaming" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                <TextBlock Text="Configuracoes para maximo desempenho em jogos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <TextBlock Text="10 opcoes" FontSize="11" Foreground="{StaticResource YokaiPurpleLight}"/>
                    </Border>
                </DockPanel>
            </Border>
            
            <!-- Gaming Features -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="FEATURES DE GAMING" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="0,0,0,16"/>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Desabilitar Game Mode" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Evita stuttering causado pelo Game Mode do Windows" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EF444420">
                                <TextBlock Text="Alto Impacto" FontSize="10" Foreground="{StaticResource YokaiRed}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Desabilitar Game Bar e DVR" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Remove overlay que consome recursos em jogos" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EF444420">
                                <TextBlock Text="Alto Impacto" FontSize="10" Foreground="{StaticResource YokaiRed}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Desabilitar Fullscreen Optimizations" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Forca tela cheia exclusiva para menor input lag" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EAB30820">
                                <TextBlock Text="Medio" FontSize="10" Foreground="{StaticResource YokaiYellow}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Otimizar GPU Scheduling" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Hardware-accelerated GPU scheduling via registro" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#22C55E20">
                                <TextBlock Text="Recomendado" FontSize="10" Foreground="{StaticResource YokaiGreen}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Otimizar CPU Priority" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Win32PrioritySeparation = 38 para apps em foreground" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#22C55E20">
                                <TextBlock Text="Recomendado" FontSize="10" Foreground="{StaticResource YokaiGreen}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Timer Resolution 0.5ms" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Reduz latencia do timer do sistema" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EAB30820">
                                <TextBlock Text="Medio" FontSize="10" Foreground="{StaticResource YokaiYellow}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Desabilitar Aceleracao do Mouse" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Input raw 1:1 para miras mais precisas" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EF444420">
                                <TextBlock Text="Alto Impacto" FontSize="10" Foreground="{StaticResource YokaiRed}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FeatureCard}">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <CheckBox Style="{StaticResource YokaiCheckBox}" IsChecked="True"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Desabilitar Efeitos Visuais" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                                    <TextBlock Text="Remove animacoes para liberar GPU" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center" Background="#EAB30820">
                                <TextBlock Text="Medio" FontSize="10" Foreground="{StaticResource YokaiYellow}"/>
                            </Border>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Apply Button -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Aplique todas as configuracoes de gaming com um clique." FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                    <Button Style="{StaticResource PrimaryBtn}" Click="Apply_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Aplicar Gaming" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>