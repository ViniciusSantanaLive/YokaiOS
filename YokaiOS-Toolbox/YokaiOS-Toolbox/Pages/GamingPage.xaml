<Page x:Class="YokaiOS_Toolbox.Pages.GamingPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Gaming" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                        <TextBlock Text="Otimizacoes para maximo desempenho em jogos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="FEATURES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="0,0,0,16"/>
                    
                    <CheckBox x:Name="ChkGameMode" Content="Desabilitar Game Mode" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkGameBar" Content="Desabilitar Game Bar e DVR" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkFSO" Content="Desabilitar Fullscreen Optimizations" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkGPUScheduling" Content="Otimizar GPU Scheduling" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkCPUPriority" Content="Otimizar CPU Priority (Win32Priority=38)" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkTimerRes" Content="Timer Resolution 0.5ms" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkMouseAccel" Content="Desabilitar Aceleracao do Mouse" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkVisualFX" Content="Desabilitar Efeitos Visuais" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <Button Style="{StaticResource PrimaryBtn}" Click="Apply_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Aplicar Gaming" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>