<Page x:Class="YokaiOS_Toolbox.Pages.GamingPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Otimizacoes Gaming" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Configuracoes para maximo desempenho em jogos" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <CheckBox Content="Desabilitar Game Mode" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Game Bar e DVR" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Fullscreen Optimizations" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Otimizar GPU Scheduling (Hardware)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Otimizar CPU Priority (Win32Priority=38)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Otimizar MMCS (Multimedia Scheduler)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Timer Resolution 0.5ms" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Aceleracao do Mouse" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Desabilitar Efeitos Visuais" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Input Raw do Mouse (1:1)" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,16"/>
                <Button Content="Aplicar Gaming" Style="{StaticResource PrimaryBtn}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
