<Page x:Class="YokaiOS_Toolbox.Pages.DebloatPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Debloat" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Remocao de bloatware e componentes desnecessarios" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <CheckBox Content="Remover Microsoft Edge" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover OneDrive" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover Copilot e IA" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover Widgets" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover Xbox Apps" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover Teams" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,8"/>
                <CheckBox Content="Remover Apps Pre-Instalados" IsChecked="True" Foreground="{StaticResource YokaiText}" Margin="0,0,0,16"/>
                <Button Content="Aplicar Debloat" Style="{StaticResource PrimaryBtn}" Click="Apply_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
