<Page x:Class="YokaiOS_Toolbox.Pages.DebloatPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" RequestedTheme="Dark">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Border Style="{StaticResource YokaiCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel>
                        <TextBlock Text="Debloat" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource YokaiTextPrimaryBrush}"/>
                        <TextBlock Text="Remocao de bloatware e componentes desnecessarios" FontSize="13" Foreground="{ThemeResource YokaiTextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <ToggleSwitch Header="Remover Microsoft Edge" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover OneDrive" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Cortana" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Copilot e IA" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Widgets" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Xbox Apps" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Teams" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Apps Pre-Instalados" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Remover Recall (IA)" OnContent="" OffContent="" IsOn="True"/>
                        <ToggleSwitch Header="Desabilitar Consumer Features" OnContent="" OffContent="" IsOn="True"/>
                    </StackPanel>
                    <Button Content="Aplicar Debloat" Style="{StaticResource YokaiButtonStyle}" Click="Apply_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
