<Page x:Class="YokaiOS_Toolbox.Pages.DebloatPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Debloat" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                    <TextBlock Text="Remocao de bloatware e componentes desnecessarios" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="COMPONENTES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="0,0,0,16"/>
                    
                    <CheckBox x:Name="ChkEdge" Content="Remover Microsoft Edge" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkOneDrive" Content="Remover OneDrive" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkCopilot" Content="Remover Copilot e IA" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkWidgets" Content="Remover Widgets" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkXbox" Content="Remover Xbox Apps" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkTeams" Content="Remover Teams" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkBloatware" Content="Remover Apps Pre-Instalados" Style="{StaticResource YokaiCheckBox}" IsChecked="True" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardBorder}">
                <Button Style="{StaticResource DangerBtn}" Click="Apply_Click">
                    <TextBlock Text="Aplicar Debloat"/>
                </Button>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>