<Page x:Class="YokaiOS_Toolbox.Pages.DashboardPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <StackPanel>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                <StackPanel>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource YokaiGreen}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="Processos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                    <TextBlock x:Name="ProcCount" Text="..." FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                    <TextBlock Text="em execucao" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4,0,4,0">
                <StackPanel>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource YokaiBlue}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="RAM" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                    <TextBlock x:Name="RamUsage" Text="..." FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                    <TextBlock Text="em uso" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="4,0,4,0">
                <StackPanel>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource YokaiPurple}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="CPU" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                    <TextBlock x:Name="CpuUsage" Text="..." FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                    <TextBlock Text="uso medio" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                <StackPanel>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource YokaiPink}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="Servicos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                    <TextBlock Text="50+" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                    <TextBlock Text="desabilitados" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Acoes Rapidas" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,4"/>
                <TextBlock Text="Execute as otimizacoes com um clique" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Aplicar Todas Otimizacoes" Style="{StaticResource PrimaryBtn}" Margin="0,0,12,0"/>
                    <Button Content="Executar Benchmark" Style="{StaticResource SecondaryBtn}" Margin="0,0,12,0"/>
                    <Button Content="Verificar Instalacao" Style="{StaticResource SecondaryBtn}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Informacoes do Sistema" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Computador" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                        <TextBlock x:Name="CompName" Text="..." FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Windows" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                        <TextBlock x:Name="WinVer" Text="..." FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="YokaiOS" FontSize="12" Foreground="{StaticResource YokaiTextMuted}"/>
                        <TextBlock Text="v2.0.0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource YokaiPurple}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
