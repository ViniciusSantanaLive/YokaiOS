<Page x:Class="YokaiOS_Toolbox.Pages.DashboardPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Background="Transparent">
    
    <Page.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource YokaiGradientCard}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource YokaiBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource YokaiPurple}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B5CF6" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- ==================== STAT CARDS ==================== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Processos -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#22C55E15" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE7EF;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{StaticResource YokaiGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="+3.2%" FontSize="11" Foreground="{StaticResource YokaiGreen}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="Processos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                        <TextBlock x:Name="ProcCount" Text="..." FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                        <TextBlock Text="em execucao" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- RAM -->
                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#3B82F615" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{StaticResource YokaiBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="-1.2 GB" FontSize="11" Foreground="{StaticResource YokaiGreen}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="RAM" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                        <TextBlock x:Name="RamUsage" Text="..." FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                        <TextBlock Text="em uso" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- CPU -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#8B5CF615" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{StaticResource YokaiPurple}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="-8%" FontSize="11" Foreground="{StaticResource YokaiGreen}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="CPU" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                        <TextBlock x:Name="CpuUsage" Text="..." FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                        <TextBlock Text="uso medio" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Servicos -->
                <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#EC489915" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{StaticResource YokaiPink}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="50+" FontSize="11" Foreground="{StaticResource YokaiPurpleLight}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="Servicos" FontSize="13" Foreground="{StaticResource YokaiText2}"/>
                        <TextBlock x:Name="SvcDisabled" Text="50+" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,4,0,0"/>
                        <TextBlock Text="desabilitados" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- ==================== QUICK ACTIONS ==================== -->
            <Border Style="{StaticResource CardBorderHover}" Margin="0,0,0,20">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,20">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Acoes Rapidas" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                            <TextBlock Text="Execute as otimizacoes com um clique" FontSize="13" Foreground="{StaticResource YokaiText2}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Style="{StaticResource YokaiBadge}" DockPanel.Dock="Right" VerticalAlignment="Center">
                            <TextBlock Text="9 categorias" FontSize="11" Foreground="{StaticResource YokaiPurpleLight}"/>
                        </Border>
                    </DockPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="ApplyAll_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74C;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Aplicar Tudo" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Grid.Column="1" Style="{StaticResource SecondaryBtn}" Margin="4,0,4,0" Click="Benchmark_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Benchmark" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Grid.Column="2" Style="{StaticResource SecondaryBtn}" Margin="8,0,0,0" Click="Verify_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Verificar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ==================== SYSTEM INFO ==================== -->
            <Border Style="{StaticResource CardBorderHover}">
                <StackPanel>
                    <TextBlock Text="Informacoes do Sistema" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,0,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="COMPUTADOR" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}"/>
                            <TextBlock x:Name="CompName" Text="..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,8,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="WINDOWS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}"/>
                            <TextBlock x:Name="WinVer" Text="..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,8,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PROCESSADOR" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}"/>
                            <TextBlock x:Name="CpuName" Text="..." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,8,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="YOKAI OS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource YokaiGreen}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="v2.0.0 - Ativo" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource YokaiPurpleLight}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <Border Style="{StaticResource YokaiSeparator}" Margin="0,20,0,0"/>
                    
                    <!-- Performance Summary -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Latencia" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Text="12ms" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource YokaiGreen}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ping medio" FontSize="11" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Disco" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Text="128 GB" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource YokaiBlue}" HorizontalAlignment="Center"/>
                            <TextBlock Text="livre de 512 GB" FontSize="11" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Uptime" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Text="2h 34m" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource YokaiPurpleLight}" HorizontalAlignment="Center"/>
                            <TextBlock Text="desde ultimo boot" FontSize="11" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>