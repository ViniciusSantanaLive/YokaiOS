<Application x:Class="YokaiOS_Toolbox.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- ==================== CORES YOKAIOS ==================== -->
        <SolidColorBrush x:Key="YokaiPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="YokaiPurpleDark" Color="#7C3AED"/>
        <SolidColorBrush x:Key="YokaiPurpleLight" Color="#A78BFA"/>
        <SolidColorBrush x:Key="YokaiPink" Color="#EC4899"/>
        <SolidColorBrush x:Key="YokaiPinkDark" Color="#DB2777"/>
        <SolidColorBrush x:Key="YokaiBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="YokaiBlueDark" Color="#2563EB"/>
        <SolidColorBrush x:Key="YokaiGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="YokaiGreenDark" Color="#16A34A"/>
        <SolidColorBrush x:Key="YokaiRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="YokaiRedDark" Color="#DC2626"/>
        <SolidColorBrush x:Key="YokaiYellow" Color="#EAB308"/>
        <SolidColorBrush x:Key="YokaiCyan" Color="#06B6D4"/>
        
        <!-- Backgrounds -->
        <SolidColorBrush x:Key="YokaiBg" Color="#09090B"/>
        <SolidColorBrush x:Key="YokaiBg2" Color="#0F0F14"/>
        <SolidColorBrush x:Key="YokaiCard" Color="#141419"/>
        <SolidColorBrush x:Key="YokaiCardHover" Color="#1A1A22"/>
        <SolidColorBrush x:Key="YokaiCardActive" Color="#1E1E28"/>
        
        <!-- Textos -->
        <SolidColorBrush x:Key="YokaiText" Color="#F4F4F5"/>
        <SolidColorBrush x:Key="YokaiText2" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="YokaiTextMuted" Color="#52525B"/>
        
        <!-- Borders -->
        <SolidColorBrush x:Key="YokaiBorder" Color="#27272A"/>
        <SolidColorBrush x:Key="YokaiBorderLight" Color="#3F3F46"/>
        
        <!-- ==================== GRADIENTES ==================== -->
        <LinearGradientBrush x:Key="YokaiGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#EC4899" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiGradientHorizontal" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#EC4899" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiGradientSubtle" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E1B4B" Offset="0"/>
            <GradientStop Color="#18181B" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiGradientCard" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#18181B" Offset="0"/>
            <GradientStop Color="#141419" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiBtnGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0"/>
            <GradientStop Color="#7C3AED" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiBtnGradientHover" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A78BFA" Offset="0"/>
            <GradientStop Color="#8B5CF6" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiDangerGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EF4444" Offset="0"/>
            <GradientStop Color="#DC2626" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="YokaiSuccessGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22C55E" Offset="0"/>
            <GradientStop Color="#16A34A" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- ==================== ESTILOS BASE ==================== -->
        
        <!-- Card Border Premium -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource YokaiGradientCard}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{StaticResource YokaiBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B5CF6" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Card Border com Hover -->
        <Style x:Key="CardBorderHover" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource YokaiPurple}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#8B5CF6" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- ==================== BOTÕES ==================== -->
        
        <!-- Botão Primário Premium -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource YokaiBtnGradient}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#8B5CF6" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource YokaiBtnGradientHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource YokaiPurpleDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Botão Secundário Premium -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource YokaiText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource YokaiCard}" CornerRadius="10" Padding="{TemplateBinding Padding}" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource YokaiCardHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource YokaiBorderLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource YokaiCardActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Botão de Perigo Premium -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource YokaiDangerGradient}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#EF4444" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F87171"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource YokaiRedDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Botão Sucesso -->
        <Style x:Key="SuccessBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource YokaiSuccessGradient}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#22C55E" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== NAVEGAÇÃO ==================== -->
        
        <!-- Botão de Navegação Premium -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource YokaiText2}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1A22"/>
                                <Setter Property="Foreground" Value="{StaticResource YokaiText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== CHECKBOX PREMIUM ==================== -->
        <Style x:Key="YokaiCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource YokaiText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder" Width="20" Height="20" CornerRadius="6" BorderBrush="{StaticResource YokaiBorderLight}" BorderThickness="2" Background="Transparent" Margin="0,0,10,0">
                                <Path x:Name="checkMark" Data="M4,9 L8,13 L16,5" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource YokaiPurple}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource YokaiPurple}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource YokaiPurpleLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== TEXTBOX PREMIUM ==================== -->
        <Style x:Key="YokaiTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource YokaiCard}"/>
            <Setter Property="Foreground" Value="{StaticResource YokaiText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="CaretBrush" Value="{StaticResource YokaiPurple}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource YokaiPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== PROGRESS BAR PREMIUM ==================== -->
        <Style x:Key="YokaiProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource YokaiBorder}"/>
            <Setter Property="Foreground" Value="{StaticResource YokaiPurple}"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" CornerRadius="3" Background="{StaticResource YokaiGradientHorizontal}"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== TOOLTIP PREMIUM ==================== -->
        <Style x:Key="YokaiToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource YokaiCard}"/>
            <Setter Property="Foreground" Value="{StaticResource YokaiText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{StaticResource YokaiCard}" CornerRadius="8" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="1" Padding="12,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000000" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ==================== SEPARADOR ==================== -->
        <Style x:Key="YokaiSeparator" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource YokaiBorder}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,12"/>
        </Style>
        
        <!-- ==================== BADGE ==================== -->
        <Style x:Key="YokaiBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#8B5CF620"/>
        </Style>
        
    </Application.Resources>
</Application>