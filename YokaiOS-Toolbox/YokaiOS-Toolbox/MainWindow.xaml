<Window x:Class="YokaiOS_Toolbox.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="YokaiOS Toolbox" 
        Width="1200" Height="750" 
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen" 
        Background="{StaticResource YokaiBg}" 
        Foreground="{StaticResource YokaiText}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- Ícones Segoe Fluent Icons -->
        <TextBlock x:Key="IconDashboard" Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconGaming" Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconPerformance" Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconPrivacy" Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconDebloat" Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconNetwork" Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconServices" Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconBenchmark" Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconRestore" Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
        <TextBlock x:Key="IconSettings" Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
    </Window.Resources>
    
    <Border Background="{StaticResource YokaiBg}" CornerRadius="12" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- ==================== TITLE BAR ==================== -->
            <Border Grid.Row="0" Background="{StaticResource YokaiBg2}" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseDown" MouseLeftButtonUp="TitleBar_MouseUp" MouseMove="TitleBar_MouseMove">
                <DockPanel>
                    <!-- Logo + Título -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Border Width="28" Height="28" CornerRadius="8" Background="{StaticResource YokaiGradient}">
                            <TextBlock Text="Y" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="YOKAI OS" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Toolbox v2.0" FontSize="11" Foreground="{StaticResource YokaiTextMuted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Botões da Janela -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="BtnMinimize" Content="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="46" Height="32" Background="Transparent" Foreground="{StaticResource YokaiText2}" BorderThickness="0" Cursor="Hand" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="&#xE739;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="46" Height="32" Background="Transparent" Foreground="{StaticResource YokaiText2}" BorderThickness="0" Cursor="Hand" Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="12" Width="46" Height="32" Background="Transparent" Foreground="{StaticResource YokaiText2}" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            
            <!-- ==================== MAIN CONTENT ==================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- ==================== SIDEBAR ==================== -->
                <Border Grid.Column="0" Background="{StaticResource YokaiBg2}" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <!-- Logo Section -->
                        <StackPanel DockPanel.Dock="Top" Margin="20,24,20,24">
                            <Border CornerRadius="16" Padding="20" Background="{StaticResource YokaiGradientSubtle}" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="1">
                                <StackPanel>
                                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource YokaiGradient}" HorizontalAlignment="Left">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="#8B5CF6" Opacity="0.4"/>
                                        </Border.Effect>
                                        <TextBlock Text="Y" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="YOKAI OS" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}" Margin="0,14,0,0"/>
                                    <TextBlock Text="Windows 11 Ultra-Optimized" FontSize="12" Foreground="{StaticResource YokaiTextMuted}" Margin="0,4,0,0"/>
                                    
                                    <!-- Badge versão -->
                                    <Border Style="{StaticResource YokaiBadge}" HorizontalAlignment="Left" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource YokaiGreen}" Margin="0,0,6,0"/>
                                            <TextBlock Text="v2.0.0 - Ativo" FontSize="11" Foreground="{StaticResource YokaiGreen}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Footer -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20">
                            <Border Style="{StaticResource YokaiSeparator}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Feito com " FontSize="11" Foreground="{StaticResource YokaiTextMuted}"/>
                                <TextBlock Text="&#xEB52;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="{StaticResource YokaiPink}" Margin="2,0"/>
                                <TextBlock Text=" para Gamers" FontSize="11" Foreground="{StaticResource YokaiTextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Navigation -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0">
                            <StackPanel>
                                <!-- Seção Principal -->
                                <TextBlock Text="PRINCIPAL" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="12,8,12,8"/>
                                
                                <Button x:Name="NavDashboard" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Dashboard">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavGaming" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Gaming">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Gaming" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavPerformance" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Performance">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Performance" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavPrivacy" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Privacy">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Privacidade" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavDebloat" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Debloat">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Debloat" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavNetwork" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Network">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Rede" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Separador -->
                                <Border Style="{StaticResource YokaiSeparator}" Margin="12,8"/>
                                
                                <!-- Seção Sistema -->
                                <TextBlock Text="SISTEMA" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="12,4,12,8"/>
                                
                                <Button x:Name="NavServices" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Services">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Servicos" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavBenchmark" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Benchmark">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Benchmark" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavRestore" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Restore">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="16" Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="Restaurar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                
                <!-- ==================== CONTENT AREA ==================== -->
                <DockPanel Grid.Column="1" Margin="32,24">
                    <!-- Header da Página -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                        <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                        <TextBlock x:Name="PageSubtitle" Text="Visao geral do sistema e acoes rapidas" FontSize="14" Foreground="{StaticResource YokaiText2}" Margin="0,4,0,0"/>
                        <Border Style="{StaticResource YokaiSeparator}" Margin="0,16,0,0"/>
                    </StackPanel>
                    
                    <!-- Frame de Conteúdo -->
                    <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
                </DockPanel>
            </Grid>
        </Grid>
    </Border>
</Window>