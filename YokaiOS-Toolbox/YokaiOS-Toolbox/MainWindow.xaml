<Window x:Class="YokaiOS_Toolbox.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="YokaiOS Toolbox" Width="1100" Height="700" WindowStartupLocation="CenterScreen" Background="{StaticResource YokaiBg}" Foreground="{StaticResource YokaiText}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource YokaiBg2}" BorderBrush="{StaticResource YokaiBorder}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" CornerRadius="10" Background="{StaticResource YokaiGradient}">
                            <TextBlock Text="Y" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="YOKAI OS" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                            <TextBlock Text="Toolbox v2.0" FontSize="11" Foreground="{StaticResource YokaiTextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,16">
                    <Border Background="{StaticResource YokaiBorder}" Height="1" Margin="0,0,0,12"/>
                    <TextBlock Text="v2.0.0" FontSize="11" Foreground="{StaticResource YokaiTextMuted}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Nav -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0">
                    <StackPanel>
                        <TextBlock Text="PRINCIPAL" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="12,8,12,4"/>
                        <Button x:Name="NavDashboard" Content="   Dashboard" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Dashboard"/>
                        <Button x:Name="NavGaming" Content="   Gaming" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Gaming"/>
                        <Button x:Name="NavPerformance" Content="   Performance" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Performance"/>
                        <Button x:Name="NavPrivacy" Content="   Privacidade" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Privacy"/>
                        <Button x:Name="NavDebloat" Content="   Debloat" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Debloat"/>
                        <Button x:Name="NavNetwork" Content="   Rede" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Network"/>
                        <TextBlock Text="SISTEMA" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource YokaiTextMuted}" Margin="12,16,12,4"/>
                        <Button x:Name="NavServices" Content="   Servicos" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Services"/>
                        <Button x:Name="NavBenchmark" Content="   Benchmark" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Benchmark"/>
                        <Button x:Name="NavRestore" Content="   Restaurar" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Restore"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <DockPanel Grid.Column="1" Margin="32">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource YokaiText}"/>
                <TextBlock x:Name="PageSubtitle" Text="Visao geral do sistema" FontSize="14" Foreground="{StaticResource YokaiText2}"/>
            </StackPanel>
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
        </DockPanel>
    </Grid>
</Window>
