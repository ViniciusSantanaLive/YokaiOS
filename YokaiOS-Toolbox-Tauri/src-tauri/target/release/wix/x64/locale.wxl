<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization"><String Id="TauriLanguage">1033</String><String Id="TauriCodepage">1252</String><String Id="LaunchApp">Launch YokaiOS Toolbox</String><String Id="DowngradeErrorMessage">A newer version of YokaiOS Toolbox is already installed.</String><String Id="PathEnvVarFeature">Add the install location of the YokaiOS Toolbox executable to the PATH system environment variable. This allows the YokaiOS Toolbox executable to be called from any location.</String><String Id="InstallAppFeature">Installs YokaiOS Toolbox.</String></WixLocalization>